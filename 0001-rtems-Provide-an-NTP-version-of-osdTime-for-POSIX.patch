+#ifndef INC_osdTime_H
+#define INC_osdTime_H
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+void osdTimeRegister(void);
+
+void osdNTPInit(void);
+int  osdNTPGet(struct timespec *);
+void osdNTPReport(void);
+
+int  osdTickRateGet(void);
+int  osdTickGet(void);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif /* INC_osdTime_H */
